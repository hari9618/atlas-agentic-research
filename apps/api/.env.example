# ============================================================
#  Atlas — Autonomous Due-Diligence Desk : environment config
#  Copy to apps/api/.env and fill in. Everything has a safe default
#  EXCEPT GROQ_API_KEY, which the LLM needs.
# ============================================================

# ---- LLM (Groq) -------------------------------------------
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# cheaper/faster model for memory-summarizer + LLM-Ops eval/optimizer
SUMMARIZER_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# ---- Memory -----------------------------------------------
# Run the summarizer (consolidate episodes -> semantic facts) every N runs.
MEMORY_CONSOLIDATE_EVERY=3

# ---- Observability (Langfuse) -----------------------------
# Self-hosted via docker-compose (LANGFUSE_HOST below) OR Langfuse Cloud.
# For Cloud, set the correct region host: https://us.cloud.langfuse.com
# or https://eu.cloud.langfuse.com  (plain cloud.langfuse.com will 401 if
# your keys are in a different region). Leave keys blank to disable tracing.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001

# ---- Vector store (Qdrant) --------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=atlas_corpus

# ---- Embeddings (free / local) ----------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANK_MODEL=BAAI/bge-reranker-base

# ---- External tools (MCP) — all optional / free tiers -----
TAVILY_API_KEY=
SEC_EDGAR_USER_AGENT=atlas-research you@example.com

# ---- App ---------------------------------------------------
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
